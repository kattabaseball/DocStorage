# =============================================================================
# TourDocs Frontend - Environment Variables
# These values are used during the build process
# For Angular, update src/environments/environment.ts directly
# This file is for Docker build args and CI/CD pipelines
# =============================================================================

# Backend API base URL (no trailing slash)
API_URL=https://localhost:7001

# SignalR hub base URL (no trailing slash)
SIGNALR_URL=https://localhost:7001/hubs

# Build configuration (development | production | staging)
BUILD_CONFIGURATION=production
