{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=TourDocs;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Secret": "SET_VIA_ENVIRONMENT_VARIABLE_OR_USER_SECRETS",
    "Issuer": "TourDocs",
    "Audience": "TourDocs",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "FileStorage": {
    "BasePath": "Storage",
    "BaseUrl": "/files",
    "MaxFileSizeBytes": 52428800
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 587,
    "Username": "",
    "Password": "",
    "UseSsl": false,
    "FromEmail": "noreply@tourdocs.com",
    "FromName": "TourDocs"
  },
  "Cors": {
    "AllowedOrigins": "http://localhost:4200"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/tourdocs-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
