# =============================================================================
# TourDocs Backend - Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit the .env file to source control
# =============================================================================

# =============================================================================
# Database
# =============================================================================
ConnectionStrings__DefaultConnection=Server=localhost;Database=TourDocs;User Id=sa;Password=YOUR_PASSWORD_HERE;TrustServerCertificate=True;MultipleActiveResultSets=True

# =============================================================================
# JWT Authentication
# =============================================================================
# Secret key for signing JWT tokens (minimum 256 bits / 32 characters)
# Generate with: openssl rand -base64 64
Jwt__Secret=YOUR_256_BIT_SECRET_KEY_HERE
Jwt__Issuer=TourDocs
Jwt__Audience=TourDocs
Jwt__AccessTokenExpirationMinutes=15
Jwt__RefreshTokenExpirationDays=7

# =============================================================================
# File Storage
# =============================================================================
# Absolute path for storing uploaded documents
FileStorage__BasePath=./Storage
FileStorage__MaxFileSizeBytes=52428800
FileStorage__AllowedExtensions=.pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png,.gif,.bmp,.tiff

# =============================================================================
# Email (SendGrid)
# =============================================================================
Email__SendGridApiKey=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
Email__FromAddress=noreply@yourdomain.com
Email__FromName=TourDocs

# =============================================================================
# Redis Cache (Optional)
# =============================================================================
Redis__ConnectionString=localhost:6379
Redis__InstanceName=TourDocs_

# =============================================================================
# Structured Logging (Seq)
# =============================================================================
Seq__ServerUrl=http://localhost:5341
Seq__ApiKey=

# =============================================================================
# CORS
# =============================================================================
Cors__AllowedOrigins=http://localhost:4200,https://localhost:4200

# =============================================================================
# Hangfire Background Jobs
# =============================================================================
Hangfire__DashboardEnabled=true
Hangfire__DashboardUsername=admin
Hangfire__DashboardPassword=YOUR_HANGFIRE_PASSWORD_HERE

# =============================================================================
# ASP.NET Core
# =============================================================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:7001;http://localhost:7000

# =============================================================================
# Rate Limiting
# =============================================================================
RateLimiting__AuthEndpointLimit=10
RateLimiting__UploadEndpointLimit=20
RateLimiting__GeneralEndpointLimit=100
RateLimiting__WindowMinutes=1

# =============================================================================
# SignalR
# =============================================================================
SignalR__MaximumReceiveMessageSize=131072
SignalR__KeepAliveInterval=15
SignalR__ClientTimeoutInterval=30
